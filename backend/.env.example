# Copiá este archivo como `.env` y ajustá los valores.
# PowerShell: Copy-Item .env.example .env

# SQLite: el archivo se crea en `prisma/dev.db` (ruta relativa al directorio prisma/)
DATABASE_URL="file:./dev.db"

# Obligatorio: secreto largo y aleatorio para firmar JWT (no compartas el de producción en el repo)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-minimo-32-caracteres"
JWT_EXPIRES_IN="7d"

PORT=3000
NODE_ENV=development

# CORS: * permite cualquier origen (útil en clase). Para Ionic/Angular en local:
# CORS_ORIGIN="http://localhost:4200,http://localhost:8100"
CORS_ORIGIN="*"
